TOKEN=your_discord_bot_token
OWNER_ID=740958995887685696
BOT_API_TOKEN=replace_with_long_random_dashboard_api_token
# Only set this to 1 for temporary local development. Production should require BOT_API_TOKEN.
ALLOW_LOCAL_API_WITHOUT_TOKEN=0
DASHBOARD_BASE_URL=/fahrstuhl

# Optional: required for Twitch Social Alerts
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=fahrstuhl
MYSQL_USER=fahrstuhl
MYSQL_PASSWORD=change_me

MYSQL_BACKUP_ENABLED=true
MYSQL_BACKUP_INTERVAL_HOURS=24
MYSQL_BACKUP_MAX_FILES=14
MYSQL_BACKUP_DIR=/app/data/mysql-backups
MYSQL_BACKUP_RUN_ON_START=false
MYSQLDUMP_PATH=/usr/bin/mysqldump
MYSQL_PATH=/usr/bin/mysql
MYSQL_BACKUP_MIN_BYTES=256

# Files Backup (tar.gz of the Fahrstuhl project, excluding node_modules/backups/logs/.git)
FILES_BACKUP_ENABLED=true
FILES_BACKUP_INTERVAL_HOURS=24
FILES_BACKUP_MAX_FILES=14
FILES_BACKUP_DIR=backups/files
FILES_BACKUP_MIN_BYTES=2048
FILES_BACKUP_INCLUDE_ENV=true
FILES_BACKUP_INCLUDE=dashboard,services,utils,scripts,docs,ecosystem.config.js,package.json,package-lock.json,.env,.env.local
FILES_BACKUP_EXCLUDE=node_modules,backups,logs,.git
TAR_PATH=/usr/bin/tar

# If true, a successful MySQL backup also triggers a Files backup with the same timestamp.
FULL_BACKUP_ON_MYSQL_RUN=true

# Whole-server backup worker (scripts/backup-worker.js + scripts/backup-all.js)
MARVIN_HOME=/home/marvin
BACKUP_ROOT=/home/marvin/backups
BACKUP_STATUS_FILE=/home/marvin/backups/backup-status.json
BACKUP_INTERVAL_MINUTES=60
BACKUP_RUN_ON_START=true
SYSTEM_BACKUP_STALE_HOURS=30
REDIS_DUMP_PATH=/var/lib/redis/dump.rdb
REDIS_AOF_PATH=/var/lib/redis/appendonly.aof
PM2_DUMP_PATH=/home/marvin/.pm2/dump.pm2

# Ops / Server Health
OPS_ALERTS_ENABLED=true
OPS_ALERT_INTERVAL_MS=300000
OPS_ALERT_COOLDOWN_MS=1800000
OPS_ALERT_STARTUP_DELAY_MS=90000
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_RECOVERY=true
OPS_HEALTH_TIMEOUT_MS=5000
OPS_DASHBOARD_RESTART_WARN_COUNT=8
OPS_DASHBOARD_MEMORY_WARN_MB=700

# Optional overrides for ops service probes (defaults point to localhost ports)
FAHRSTUHL_HEALTH_URL=http://127.0.0.1:3002/health
DASHBOARD_PHP_HEALTH_URL=http://127.0.0.1:8081/health
DEPLOY_WEBHOOK_HEALTH_URL=http://127.0.0.1:9000/health
ESELTOKENS_HEALTH_URL=http://127.0.0.1:3000/
ESELTOKENS_WEBHOOK_HEALTH_URL=http://127.0.0.1:9001/health
FILEHOSTER_HEALTH_URL=http://127.0.0.1:3011/health
LINKSHORTENER_HEALTH_URL=http://127.0.0.1:3010/health
ZITATBOARD_HEALTH_URL=http://127.0.0.1:3013/health
STATUSPAGE_HEALTH_URL=http://127.0.0.1:3012/health
TEAM_HEALTH_URL=http://127.0.0.1:3014/health
ESEL_HEALTH_URL=http://127.0.0.1:3015/health
ESELMUSIC_HEALTH_URL=http://127.0.0.1:3020/health

# Optional Redis/Lavalink probe overrides for the ops dashboard
OPS_REDIS_HOST=127.0.0.1
OPS_REDIS_PORT=6379
NGINX_SITES_ENABLED_DIR=/etc/nginx/sites-enabled

# Slash command registration
COMMAND_REGISTRATION_ON_START=true
COMMAND_REGISTRATION_FORCE=false
COMMAND_REGISTRATION_CLEAR_GLOBAL=false

# Troll Command Timings (in milliseconds)
TROLL_AUTOMOVE_INTERVAL=2500
TROLL_FORCED_DURATION=30000
TROLL_GHOST_VISIT_MIN=600000
TROLL_GHOST_VISIT_MAX=1200000
TROLL_SILENT_POST_INTERVAL=10000
TROLL_SILENT_POST_DURATION=1000
TROLL_DEAF_INTERVAL=10000
TROLL_DEAF_DURATION=1000

# Bot Timings
BOT_STATS_UPDATE_INTERVAL=600000
BOT_GLOBAL_STATS_FLUSH=10000
BOT_COMMAND_COOLDOWN=500
BOT_PRESENCE_UPDATE_INTERVAL=300000

# Voice activity -> EselTokens rewards
# Empfehlung: 1 Token pro 10 Voice-Minuten, mindestens 5 Minuten Session, max cap handled by EselTokens.
VOICE_REWARD_ENABLED=false
VOICE_REWARD_MINUTES_PER_TOKEN=10
VOICE_REWARD_MIN_SESSION_MINUTES=5
VOICE_REWARD_PROCESS_INTERVAL_MS=300000
VOICE_REWARD_BATCH_SIZE=100
ESELTOKENS_VOICE_REWARD_URL=http://127.0.0.1:3000/eseltokens/api/integrations/fahrstuhl/voice-reward
ESELTOKENS_VOICE_REWARD_SECRET=change_me_same_as_eseltokens

# Leveling
LEVELING_MESSAGE_XP_MIN=8
LEVELING_MESSAGE_XP_MAX=15
LEVELING_MESSAGE_COOLDOWN_MS=0

# Auto-Deploy Webhook (scripts/deploy-webhook.js)
DEPLOY_SECRET=change_me_random_string
DEPLOY_WEBHOOK_PORT=9000
DEPLOY_BRANCH=main

# EselTokens Auto-Deploy Webhook (scripts/eseltokens-webhook.js)
ESELTOKENS_DEPLOY_SECRET=change_me_random_string
ESELTOKENS_WEBHOOK_PORT=9001
ESELTOKENS_REPO_DIR=/home/marvin/eseltokens
ESELTOKENS_DEPLOY_BRANCH=main
