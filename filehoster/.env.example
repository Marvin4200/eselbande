# Optional: Redis-backed session store (recommended for PM2 cluster mode)
# Without this, sessions are stored in-memory (per-process, lost on restart).
# Run `npm install` after adding REDIS_URL to install ioredis + connect-redis.
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_REQUIRED=false
